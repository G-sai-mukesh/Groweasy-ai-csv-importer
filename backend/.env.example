# Server
PORT=4000
NODE_ENV=development

# Comma-separated list of allowed CORS origins (your frontend URL)
CORS_ORIGIN=http://localhost:3000

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-flash-latest

# CSV processing
MAX_FILE_SIZE_MB=5
BATCH_SIZE=25
BATCH_CONCURRENCY=3
AI_MAX_RETRIES=3
